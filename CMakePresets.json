{
    "version": 3,
    "configurePresets": [
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "description": "面向适用于 Linux 的 Windows 子系统(WSL)或远程 Linux 系统。",
            "installDir": "${sourceDir}/cmake/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },

        {
            "name": "macos-debug",
            "displayName": "macOS Debug",
            "description": "以远程 macOS 系统为目标。",
            "installDir": "${sourceDir}/cmake/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },
        {
            "name": "windows-base",
            "description": "面向具有 Visual Studio 开发环境的 Windows。",
            "hidden": true,
            "installDir": "${sourceDir}/cmake/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PLATFORM": "x64",
                "CMAKE_BUILD_PARALLEL_LEVEL": "12",
                "CMAKE_CXX_STANDARD": "11",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/g++.exe",
                "CMAKE_C_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "$env{QT_X64_MinGW_Tool}/bin/mingw32-make.exe"
                //"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                //"VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg",
                //"VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            },
            "generator": "MinGW Makefiles"
        },

        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "description": "使用 Visual Studio 开发环境定向到 Windows (64 位)。(Debug)",
            "inherits": "windows-base",
            "binaryDir": "${sourceDir}/cmake/build/X64-Debug",
            "architecture": {
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PLATFORM": "x64",
                "CMAKE_SIZEOF_VOID_P": "8",
                "CMAKE_BUILD_PARALLEL_LEVEL": "12",
                "CMAKE_CXX_STANDARD": "11",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/g++.exe",
                "CMAKE_C_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "$env{QT_X64_MinGW_Tool}/bin/mingw32-make.exe",
                "CMAKE_CXX_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc -static-libstdc++",
                "CMAKE_C_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc"
            },
            "environment": {
                "PATH": "$env{QT_X64_MinGW_Tool}/bin;$env{VCPKG_ROOT}/installed/x86-mingw-dynamic/bin;",
                "INCLUDE": "$env{QT_X64_MinGW_Tool}/include;",
                "LIB": "$env{QT_X64_MinGW_Tool}/lib;"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "intelliSenseMode": "linux-gcc-x64"
                }
            },
            "generator":"MinGW Makefiles"
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release",
            "description": "使用 Visual Studio 开发环境定向到 Windows (64 位)。(RelWithDebInfo)",
            "inherits": "x64-debug",
            "binaryDir": "${sourceDir}/cmake/build/X64-Release",
            "cacheVariables": {
                "CMAKE_VERBOSE_MAKEFILE": "ON",
                "CMAKE_TRY_COMPILE_VERBOSE_FLAG": "ON",
                "CMAKE_BUILD_TYPE": "Release",
                "PLATFORM": "x64",
                "CMAKE_SIZEOF_VOID_P": "8",
                "CMAKE_BUILD_PARALLEL_LEVEL": "12",
                "CMAKE_CXX_STANDARD": "11",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/g++.exe",
                "CMAKE_C_COMPILER": "$env{QT_X64_MinGW_Tool}/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "$env{QT_X64_MinGW_Tool}/bin/mingw32-make.exe",
                "CMAKE_CXX_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc -static-libstdc++",
                "CMAKE_C_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc"
            },
            "environment": {
                "PATH": "$env{QT_X64_MinGW_Tool}/bin;$env{VCPKG_ROOT}/installed/x86-mingw-dynamic/bin;",
                "INCLUDE": "$env{QT_X64_MinGW_Tool}/include;",
                "LIB": "$env{QT_X64_MinGW_Tool}/lib;"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "intelliSenseMode": "linux-gcc-x64"
                }
            },
            "generator": "MinGW Makefiles"
        },
        {
            "name": "x86-debug",
            "displayName": "x86 Debug",
            "description": "用 Visual Studio 开发环境定向到 Windows (32 位)。(Debug)",
            "inherits": "windows-base",
            "binaryDir": "${sourceDir}/cmake/build/X86-Debug",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PLATFORM": "x86",
                "CMAKE_SIZEOF_VOID_P": "4",
                "CMAKE_BUILD_PARALLEL_LEVEL": "12",
                "CMAKE_CXX_STANDARD": "11",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_COMPILER": "$env{QT_X86_MinGW_Tool}/bin/g++.exe",
                "CMAKE_C_COMPILER": "$env{QT_X86_MinGW_Tool}/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "$env{QT_X86_MinGW_Tool}/bin/mingw32-make.exe",
                "CMAKE_CXX_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc -static-libstdc++",
                "CMAKE_C_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc"
            },
            "environment": {
                "PATH": "$env{QT_X86_MinGW_Tool}/bin;$env{VCPKG_ROOT}/installed/x86-mingw-dynamic/bin;",
                "INCLUDE": "$env{QT_X86_MinGW_Tool}/include;",
                "LIB": "$env{QT_X86_MinGW_Tool}/lib;"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "intelliSenseMode": "linux-gcc-x86"
                }
            },
            "generator": "MinGW Makefiles"
        },
        {
            "name": "x86-release",
            "displayName": "x86 Release",
            "description": "用 Visual Studio 开发环境定向到 Windows (32 位)。(RelWithDebInfo)",
            "inherits": "x86-debug",
            "binaryDir": "${sourceDir}/cmake/build/X86-Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PLATFORM": "x86",
                "CMAKE_SIZEOF_VOID_P": "4",
                "CMAKE_BUILD_PARALLEL_LEVEL": "12",
                "CMAKE_CXX_STANDARD": "11",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_COMPILER": "$env{QT_X86_MinGW_Tool}/bin/g++.exe",
                "CMAKE_C_COMPILER": "$env{QT_X86_MinGW_Tool}/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "$env{QT_X86_MinGW_Tool}/bin/mingw32-make.exe",
                "CMAKE_CXX_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc -static-libstdc++",
                "CMAKE_C_FLAGS": "-fexec-charset=utf-8 -finput-charset=utf-8 -static-libgcc"
            },
            "environment": {
                "PATH": "$env{QT_X86_MinGW_Tool}/bin;$env{VCPKG_ROOT}/installed/x86-mingw-dynamic/bin;",
                "INCLUDE": "$env{QT_X86_MinGW_Tool}/include;",
                "LIB": "$env{QT_X86_MinGW_Tool}/lib;"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "intelliSenseMode": "linux-gcc-x86"
                }
            },
            "generator": "MinGW Makefiles"
        }
    ],
    "buildPresets": [
        {
            "name": "X64-debug-build",
            "description": "Build the project in Debug mode for x64",
            "displayName": "x64 Debug Build",
            "inheritConfigureEnvironment": true,
            "targets": [
                "all"
            ],
            "verbose": true,
            "jobs": 14,
            "configurePreset": "x64-debug"
        },
        {
            "name": "X64-release-build",
            "description": "Build the project in Release mode for x64",
            "displayName": "x64 Release Build",
            "inheritConfigureEnvironment": true,
            "targets": [
                "all"
            ],
            "verbose": true,
            "jobs": 14,
            "configurePreset": "x64-release"
        },
        {
            "name": "X86-debug-build",
            "description": "Build the project in Debug mode for x86",
            "displayName": "x86 Debug Build",
            "inheritConfigureEnvironment": true,
            "targets": [
                "all"
            ],
            "verbose": true,
            "jobs": 14,
            "configurePreset": "x86-debug"
        },
        {
            "name": "X86-release-build",
            "description": "Build the project in Release mode for x86",
            "displayName": "x86 Release Build",
            "inheritConfigureEnvironment": true,
            "targets": [
                "all"
            ],
            "verbose": true,
            "jobs": 14,
            "configurePreset": "x86-release"
        }
    ],
    "testPresets": [
        {
            "name": "test1-debug",
            "displayName": "Test1 Debug",
            "description": "Run the test1 in Debug mode",
            "configurePreset": "x64-debug",
            "output": {
                "outputLogFile": "../cmake/test_output.log",
                "verbosity": "verbose",
                "debug": true,
                "outputOnFailure": true,
                "maxFailedTestOutputSize": 1024,
                "shortProgress": true
            }
        }
    ]
}